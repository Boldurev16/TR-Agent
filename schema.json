          "title_ru": "Дата согласования карточки прототипа",
          "source_mapping": "IdeaSubmissionDate = Item(Idea Submission Date),In(BasicGroup)",
          "type": "date",
          "format": "YYYY-MM-DD",
          "required": false
        },
        {
          "name": "data_nachala_rabot_po_protipirovaniyu",
          "title_ru": "Дата начала работ по протипированию",
          "source_mapping": "IdeaStartDate = Item(Idea Start Date),In(BasicGroup),Name(\"Start Date\")",
          "type": "date",
          "format": "YYYY-MM-DD",
          "required": false
