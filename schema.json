          "required": false,
          "enum_hint": "dictionary"
        },
        {
          "name": "opisanie_funktsionalnosti",
          "title_ru": "Описание функциональности",
          "source_mapping": "IdeaExpectedValue = Item(Comment),In(NameGroup),Control(Text),Name(\"Description\")",
          "type": "string",
          "required": false
        },
        {
