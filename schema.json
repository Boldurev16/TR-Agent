          "source_mapping": "Prerequisites = Item(Prerequisites),In(BasicGroup),Control(Text),Name(\"Prerequisites <Background>\")",
          "type": "string",
          "required": false
        },
        {
          "name": "stadiya_vyberite_iz_vypadayuschego_spiska",
