{
  "schema_name": "it_idea_normalization_schema",
  "schema_version": "1.0.0",
  "source_file": "Edinaia-model-dannykh-IT-idei-Shema.xlsx",
  "source_sheet": "Общая модель",
  "description": "Schema.json для нормализации данных карточек ИТ-идей / прототипов с использованием LLM (Gemma 4, Cursor и др.).",
  "normalization_rules": [
    "Сохранять исходные значения полей без потери смысла.",
    "Даты приводить к формату YYYY-MM-DD, если точная дата присутствует.",
    "Поля с Да/Нет нормализовать в boolean true/false, сохраняя raw_value при неоднозначности.",
    "Поля-справочники не придумывать; использовать значение источника как raw_value и canonical_value при наличии словаря.",
    "Пустые или отсутствующие значения записывать как null."
  ],
  "entities": [
    {
      "name": "idea",
      "title": "IT Idea / Prototype Card",
      "description": "Нормализованная логическая модель карточки ИТ-идеи / прототипа на основе листа «Общая модель».",
      "primary_key": "ea_tool_code",
      "fields": [
        {
          "name": "kod_ea_tool",
          "title_ru": "Код EA Tool",
          "source_mapping": "Absolute Identifier",
          "type": "string",
          "required": true
        },
        {
          "name": "naimenovanie_prototipa_it_resheniya_iz_kartochki_prototipa_it_intsiativy",
          "title_ru": "Наименование прототипа ИТ-решения (из карточки прототипа/ИТ-инциативы)",
          "source_mapping": "IdeaName = Item(Generic Local name),In(BasicGroup),Name(\"Idea Name\")",
          "type": "string",
          "required": false
        },
        {
          "name": "predposylki_dlya_prototipirovaniya_tema_issledovaniya_opisanie_potrebnosti_i_biznes_gipotezy",
